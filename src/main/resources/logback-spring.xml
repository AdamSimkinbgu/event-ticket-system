<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logger configuration for the Event Ticket System.
    SLR.8.1 (telemetry) + SLR.8.2 (real-time error logging) anchor here.
    Lecture 2 rule: NEVER log secrets, tokens, passwords, or PII.

    Application services use Lombok @Slf4j for SLF4J injection.
    Cross-cutting entry/exit tracing is handled by LoggingAspect (DEBUG level on the
    "com.ticketing.system.Infrastructure.logging" logger).
    Domain code may also use @Slf4j for WARN/ERROR; everything funnels to the same file.
-->
<configuration>

    <!-- Console appender — primary output during dev and CI. -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Rolling file appender — for production / acceptance runs. -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/event-ticket-system.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/event-ticket-system.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Default profile (prod): INFO to file + console. -->
    <springProfile name="default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.ticketing.system" level="INFO"/>
        <!-- Domain warnings/errors always reach the file -->
        <logger name="com.ticketing.system.Core.Domain" level="WARN"/>
        <!-- AOP entry/exit tracing off in prod by default -->
        <logger name="com.ticketing.system.Infrastructure.logging" level="INFO"/>
    </springProfile>

    <!-- Dev profile: local run with Memory* repos + demo seed (no DB). Console + rolling file. -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.ticketing.system" level="DEBUG"/>
        <logger name="com.ticketing.system.Core.Domain" level="DEBUG"/>
        <logger name="com.ticketing.system.Infrastructure.logging" level="DEBUG"/>
    </springProfile>

    <!-- JPA run profiles (supabase / plain `jpa` deploy) — but NOT dev, which has its own block
         above (dev activates jpa via profiles.group, so the `& !dev` avoids double-logging). Without
         this, a supabase/jpa run matches no <springProfile> and gets NO appenders at all (silent). -->
    <springProfile name="jpa &amp; !dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.ticketing.system" level="INFO"/>
        <logger name="com.ticketing.system.Core.Domain" level="WARN"/>
        <logger name="com.ticketing.system.Infrastructure.logging" level="INFO"/>
    </springProfile>

    <!-- Test profile: DEBUG for our code, console only. -->
    <springProfile name="test">
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.ticketing.system" level="DEBUG"/>
        <logger name="com.ticketing.system.Core.Domain" level="DEBUG"/>
        <logger name="com.ticketing.system.Infrastructure.logging" level="DEBUG"/>
    </springProfile>

    <!-- Acceptance profile: INFO, console + file. -->
    <springProfile name="acceptance">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.ticketing.system" level="DEBUG"/>
        <logger name="com.ticketing.system.Core.Domain" level="DEBUG"/>
        <logger name="com.ticketing.system.Infrastructure.logging" level="DEBUG"/>
    </springProfile>

</configuration>

# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# macOS
.DS_Store

# Maven build output
target/

# Excel / Google Sheets exports
*.csv
*.xlsx
*.xls

# Vaadin (V2-F-01) — frontend build artifacts auto-generated by vaadin-maven-plugin.
# `src/main/frontend/index.html` IS committed (customizable entry point);
# everything under src/main/frontend/generated/ is auto-rebuilt and ignored.
node_modules/
src/main/dev-bundle/
src/main/bundles/
src/main/frontend/generated/
**/vite.generated.ts
**/vite.config.ts.timestamp-*
.vaadin/

scripts/*
docs/*

# Runtime log output (logs/event-ticket-system.log + rolled .gz archives)
logs/

# Claude Code per-project skills + agent tooling (run skill, drivers, screenshots).
.claude/
